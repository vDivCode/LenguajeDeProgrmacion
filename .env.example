# ============================================================
# .env.example — Plantilla de variables de entorno
# COPIA este archivo como ".env" y rellena tus valores reales
# NO subas .env a git (ya está en .gitignore)
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Supabase ---
# Encuéntralos en: https://supabase.com/dashboard → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
